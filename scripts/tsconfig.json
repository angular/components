{
  "compilerOptions": {
    "outDir": "../dist/dev-infra-scripts",
    "rootDir": "../",
    "target": "es2020",
    "lib": ["es2020"],
    "module": "Node16",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
